# Supabase — production values from Supabase Cloud project settings.
# These are baked into the JS bundle at BUILD TIME (Vite replaces import.meta.env
# at build), so Railway must have them set BEFORE the build runs.
#
# Local dev: see `supabase status` output after `supabase start` runs.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
