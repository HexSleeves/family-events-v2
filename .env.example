# Supabase — production values from Supabase Cloud project settings.
# These are baked into the JS bundle at BUILD TIME (Vite replaces import.meta.env
# at build), so Railway must have them set BEFORE the build runs.
#
# Local dev: see `supabase status` output after `supabase start` runs.
#
# Optional Postgres connection string for direct database access.
# Replace [YOUR-PASSWORD] with the actual database password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side / verification only (never expose client-side):
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_key_here
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=replace-with-secure-password

# Optional helper for scripts/verify-edge-fn.mjs
VERIFY_SOURCE_ID=replace-with-safe-source-uuid

# Sentry browser SDK
VITE_SENTRY_DSN=https://YOUR_PUBLIC_KEY@YOUR_ORG_ID.ingest.us.sentry.io/YOUR_PROJECT_ID
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
