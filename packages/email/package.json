{
  "name": "@family-events/email",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "deploy": "tsx scripts/deploy-templates.tsx",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "oxfmt --config ../config-quality/oxfmt.base.json --write src emails scripts",
    "format:check": "oxfmt --config ../config-quality/oxfmt.base.json --check src emails scripts"
  },
  "dependencies": {
    "@react-email/render": "latest",
    "react-email": "latest",
    "resend": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@family-events/config-quality": "workspace:*",
    "@family-events/config-typescript": "workspace:*",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tsx": "latest"
  }
}
