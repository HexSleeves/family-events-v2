{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "family-events design tokens",
    "version": "0.3.0",
    "designRef": "docs/DESIGN.md",
    "lockedAt": "2026-05-25"
  },
  "color": {
    "light": {
      "bg": { "oklch": "97% 0.008 285", "hex": "#F5F3FC", "role": "lavender-white bedrock (H look)" },
      "surface": { "oklch": "99% 0.005 290", "hex": "#FDFCFF", "role": "cards, sheets, admin panels" },
      "surface-raised": { "oklch": "93% 0.015 285", "hex": "#E8E4F5", "role": "elevated panels" },
      "text-primary": { "oklch": "20% 0.025 295", "hex": "#1C1828", "role": "deep violet-plum" },
      "text-muted": { "oklch": "46% 0.022 305", "hex": "#6B6278", "role": "secondary text" },
      "border": { "oklch": "82% 0.016 285", "hex": "#CAC5DC", "role": "hairlines" },
      "accent-primary": { "oklch": "52% 0.160 290", "hex": "#7B5CC8", "role": "violet — brand anchor (H)" },
      "accent-primary-soft": { "oklch": "92% 0.045 290", "hex": "#E6DEFF", "role": "pill bg, hover tints" },
      "accent-secondary": { "oklch": "72% 0.130 52", "hex": "#E89060", "role": "peach — save, plan, this-weekend" },
      "accent-secondary-soft": { "oklch": "93% 0.038 52", "hex": "#F8E3D0", "role": "action chip bg" },
      "accent-tertiary": { "oklch": "54% 0.070 248", "hex": "#5A7EA8", "role": "muted blue — location, admin, info" },
      "accent-tertiary-soft": { "oklch": "91% 0.028 245", "hex": "#D2E3F0", "role": "location-band bg" },
      "accent-kid": { "oklch": "76% 0.170 78", "hex": "#D4AA28", "role": "golden yellow — kid affordances only (D)" },
      "accent-kid-soft": { "oklch": "93% 0.070 80", "hex": "#F2E8A0", "role": "kid pill bg" },
      "success": { "oklch": "48% 0.085 155", "hex": "#2E7D5B", "role": "confirmed states" },
      "warning": { "oklch": "60% 0.13 70", "hex": "#B7791F", "role": "rain forecast, soft warnings" },
      "error": { "oklch": "55% 0.16 25", "hex": "#B94A48", "role": "destructive, validation fails" },
      "info": { "oklch": "54% 0.070 248", "hex": "#5A7EA8", "role": "informational (matches tertiary)" }
    },
    "dark": {
      "bg": { "oklch": "22% 0.020 285", "hex": "#1E1C2E", "role": "violet-dark — lighter than slate, never pure black" },
      "surface": { "oklch": "26% 0.024 285", "hex": "#272436", "role": "elevated cards" },
      "surface-raised": { "oklch": "30% 0.028 285", "hex": "#312D42", "role": "higher elevation" },
      "text-primary": { "oklch": "94% 0.012 295", "hex": "#EDEAF6", "role": "cool lavender-white" },
      "text-muted": { "oklch": "65% 0.018 290", "hex": "#9690B0", "role": "secondary text" },
      "border": { "oklch": "34% 0.022 285", "hex": "#45405A", "role": "hairlines" },
      "accent-primary": { "oklch": "70% 0.140 290", "hex": "#A48EE8", "role": "lightened violet" },
      "accent-primary-soft": { "oklch": "26% 0.065 290", "hex": "#2C2448", "role": "pill bg dark" },
      "accent-secondary": { "oklch": "78% 0.095 52", "hex": "#E8A882", "role": "lightened peach" },
      "accent-secondary-soft": { "oklch": "26% 0.072 45", "hex": "#4A2E22", "role": "action chip bg dark" },
      "accent-tertiary": { "oklch": "65% 0.070 250", "hex": "#7899C0", "role": "lightened blue" },
      "accent-tertiary-soft": { "oklch": "24% 0.045 250", "hex": "#1E2E44", "role": "location-band bg dark" },
      "accent-kid": { "oklch": "80% 0.155 78", "hex": "#D8B838", "role": "golden yellow — holds on violet-dark (D)" },
      "accent-kid-soft": { "oklch": "26% 0.080 78", "hex": "#3C3010", "role": "kid pill bg dark" },
      "success": { "oklch": "65% 0.1 155", "hex": "#56A580", "role": "confirmed" },
      "warning": { "oklch": "72% 0.14 70", "hex": "#D69845", "role": "warnings" },
      "error": { "oklch": "68% 0.16 25", "hex": "#D77370", "role": "destructive" },
      "info": { "oklch": "65% 0.070 250", "hex": "#7899C0", "role": "info" }
    }
  },
  "space": {
    "1": { "px": 4 },
    "2": { "px": 8 },
    "3": { "px": 12 },
    "4": { "px": 16 },
    "5": { "px": 24 },
    "6": { "px": 32 },
    "7": { "px": 48 },
    "8": { "px": 64 },
    "9": { "px": 96 }
  },
  "radius": {
    "sm": { "px": 6, "role": "admin controls, dense buttons, inputs" },
    "md": { "px": 8, "role": "consumer event cards" },
    "lg": { "px": 12, "role": "mobile bottom sheets, high-touch panels" },
    "full": { "px": 9999, "role": "pills, avatars, segmented toggles" }
  },
  "typography": {
    "family": {
      "display": {
        "stack": "Fraunces, ui-serif, Georgia, serif",
        "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..700,30..100&display=swap",
        "role": "event titles, hero, section headers, app name"
      },
      "body": {
        "stack": "\"DM Sans\", ui-sans-serif, system-ui, sans-serif",
        "googleFontsUrl": "https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300..700&display=swap",
        "role": "filters, cards, buttons, labels, tab bar"
      },
      "editorial": {
        "stack": "Newsreader, ui-serif, Georgia, serif",
        "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght,ital@6..72,400..700,0;6..72,400..700,1&display=swap",
        "role": "curator notes, source descriptions"
      },
      "mono": {
        "stack": "\"Geist Mono\", ui-monospace, \"SF Mono\", monospace",
        "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400..700&display=swap",
        "role": "price, distance, age range, admin tables"
      }
    },
    "scale": {
      "2xs": { "mobile": { "px": 11, "lh": 1.4 }, "desktop": { "px": 11, "lh": 1.4 }, "role": "mono captions" },
      "xs": { "mobile": { "px": 12, "lh": 1.45 }, "desktop": { "px": 12, "lh": 1.45 }, "role": "mono metadata" },
      "sm": { "mobile": { "px": 14, "lh": 1.5 }, "desktop": { "px": 14, "lh": 1.5 }, "role": "helper, pill labels" },
      "base": { "mobile": { "px": 16, "lh": 1.55 }, "desktop": { "px": 16, "lh": 1.55 }, "role": "body — never smaller on mobile" },
      "md": { "mobile": { "px": 18, "lh": 1.5 }, "desktop": { "px": 20, "lh": 1.5 }, "role": "editorial body" },
      "lg": { "mobile": { "px": 22, "lh": 1.3 }, "desktop": { "px": 26, "lh": 1.3 }, "role": "secondary card title" },
      "xl": { "mobile": { "px": 28, "lh": 1.15 }, "desktop": { "px": 34, "lh": 1.15 }, "role": "hero card title" },
      "2xl": { "mobile": { "px": 36, "lh": 1.1 }, "desktop": { "px": 44, "lh": 1.1 }, "role": "page title display" },
      "3xl": { "mobile": { "px": 44, "lh": 1.05 }, "desktop": { "px": 60, "lh": 1.05 }, "role": "marketing hero only" }
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    }
  },
  "motion": {
    "duration": {
      "micro": "100ms",
      "short": "200ms",
      "medium": "320ms",
      "long": "500ms"
    },
    "easing": {
      "out": "cubic-bezier(0.16, 1, 0.3, 1)",
      "in-out": "cubic-bezier(0.65, 0, 0.35, 1)",
      "spring-soft": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "breakpoint": {
    "xs": { "px": 320, "role": "iPhone SE / smallest" },
    "sm": { "px": 480, "role": "larger phone" },
    "md": { "px": 640, "role": "small tablet / split" },
    "lg": { "px": 900, "role": "tablet / desktop entry" },
    "xl": { "px": 1200, "role": "desktop comfortable" },
    "2xl": { "px": 1440, "role": "desktop wide" }
  },
  "shadow": {
    "sm": { "value": "0 1px 2px 0 rgb(40 30 20 / 0.05)" },
    "md": { "value": "0 4px 8px -2px rgb(40 30 20 / 0.08), 0 2px 4px -2px rgb(40 30 20 / 0.04)" },
    "lg": { "value": "0 12px 24px -6px rgb(40 30 20 / 0.1), 0 4px 8px -2px rgb(40 30 20 / 0.05)" },
    "hero": { "value": "0 30px 60px -30px rgb(40 30 20 / 0.18)" }
  },
  "z": {
    "base": 0,
    "raised": 1,
    "sticky": 10,
    "dropdown": 50,
    "drawer": 60,
    "modal": 70,
    "popover": 80,
    "toast": 90,
    "tooltip": 100
  },
  "touch": {
    "min": { "px": 44, "role": "WCAG / iOS HIG minimum hit area" }
  },
  "containerQueries": {
    "card-sm": { "px": 280 },
    "card-md": { "px": 380 },
    "card-lg": { "px": 520 }
  }
}
