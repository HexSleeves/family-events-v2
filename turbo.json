{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "ANDROID_GOOGLE_WEB_CLIENT_ID",
    "ANDROID_HOME",
    "ANDROID_SDK_ROOT",
    "JAVA_HOME",
    "MAP_STYLE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_URL"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        "out/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "@family-events/web#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "../../node_modules/.tmp/apps-web*.tsbuildinfo"]
    },
    "@family-events/design-system#build": {
      "dependsOn": ["^build"],
      "outputs": [
        "src/generated/**",
        "../../apps/web/src/styles/tokens.generated.css",
        "../../apps/ios/Packages/FEDesignSystem/Sources/FEDesignSystem/Generated/Tokens.swift",
        "../../apps/android/designsystem/src/main/java/com/familyevents/designsystem/generated/Tokens.kt"
      ]
    },
    "@family-events/android#build": {
      "dependsOn": ["^build"],
      "outputs": [
        "*/build/outputs/**",
        "*/build/reports/**",
        "*/build/test-results/**",
        "build/reports/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
