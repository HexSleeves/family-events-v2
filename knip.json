{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "include": ["files", "dependencies", "unlisted", "binaries"],
  "ignoreBinaries": ["terraform"],
  "ignoreIssues": {
    "supabase/functions/**/*.ts": ["unlisted"]
  },
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "entry": [".agents/**/*.ts", "scripts/*.mjs", "tests/**/*.mjs", "tests/**/*.ts"],
      "project": [".agents/**/*.ts", "scripts/*.mjs", "tests/**/*.mjs", "tests/**/*.ts"]
    },
    "apps/android": {
      "ignoreBinaries": ["scripts/with-android-env.sh"]
    },
    "apps/ios": {
      "ignoreBinaries": ["awk", "swift", "xcode-select", "xcodegen", "xcrun"]
    },
    "apps/web": {
      "entry": [
        "src/main.tsx!",
        "src/env.d.ts",
        "vite.config.ts!",
        "vitest.config.ts",
        "playwright.config.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "e2e/**/*.ts"
      ],
      "project": ["src/**/*.ts!", "src/**/*.tsx!", "e2e/**/*.ts", "*.config.ts!"],
      "vite": false,
      "ignoreDependencies": [
        "@family-events/design-system",
        "tailwindcss",
        "tw-animate-css"
      ]
    },
    "packages/contracts": {
      "ignoreDependencies": [
        "@family-events/config-quality",
        "@family-events/config-typescript"
      ]
    },
    "packages/design-system": {
      "entry": ["scripts/*.mjs"],
      "project": ["src/**/*.ts", "scripts/*.mjs"],
      "ignoreDependencies": [
        "@family-events/config-quality",
        "@family-events/config-typescript"
      ],
      "ignoreFiles": ["src/generated/**"]
    },
    "packages/email": {
      "entry": ["src/index.ts!", "scripts/deploy-templates.tsx!", "emails/**/*.tsx!"],
      "project": ["src/**/*.ts!", "emails/**/*.tsx!", "scripts/**/*.tsx!"],
      "react-email": false,
      "ignoreDependencies": ["@family-events/config-typescript"]
    },
    "packages/shared": {
      "ignoreDependencies": [
        "@family-events/config-quality",
        "@family-events/config-typescript"
      ]
    },
    "supabase/functions": {
      "entry": ["**/*.ts"],
      "project": ["**/*.ts"]
    }
  }
}
