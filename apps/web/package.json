{
  "name": "@family-events/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite",
    "dev:hosted": "vite --mode hosted",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l ${PORT:-3000}",
    "typecheck": "tsc -b",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --config ../../packages/config-quality/oxfmt.base.json --write src",
    "format:check": "oxfmt --config ../../packages/config-quality/oxfmt.base.json --check src",
    "check": "tsc -b && pnpm run lint && pnpm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist .next out"
  },
  "dependencies": {
    "@family-events/contracts": "workspace:*",
    "@family-events/design-system": "workspace:*",
    "@family-events/shared": "workspace:*",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.106.1",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.100.13",
    "@tanstack/react-virtual": "^3.13.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-map-gl": "^8.1.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@family-events/config-typescript": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supercluster": "^7.1.3",
    "@vitejs/plugin-react": "^6.0.2",
    "serve": "^14.2.6",
    "vite": "^8.0.14"
  }
}
