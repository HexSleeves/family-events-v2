#!/bin/sh

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
JAVA_EXE=${JAVA_HOME:-}/bin/java
if [ ! -x "$JAVA_EXE" ]; then
  JAVA_EXE=java
fi

if "$JAVA_EXE" --enable-native-access=ALL-UNNAMED -version >/dev/null 2>&1; then
  exec "$JAVA_EXE" --enable-native-access=ALL-UNNAMED -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
else
  exec "$JAVA_EXE" -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
fi
