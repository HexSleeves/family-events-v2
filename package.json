{
  "name": "family-events-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l ${PORT:-3000}",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "check": "tsc --noEmit && pnpm run lint && pnpm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "supabase:start": "bash scripts/supabase.sh start",
    "supabase:dev": "bash scripts/supabase.sh start && npm run setup:local && bash scripts/supabase.sh functions serve",
    "supabase:stop": "bash scripts/supabase.sh stop",
    "supabase:stop:id": "bash scripts/supabase.sh stop --project-id",
    "supabase:status": "bash scripts/supabase.sh status",
    "supabase:migrate": "bash scripts/supabase.sh db push",
    "supabase:db:reset": "bash scripts/supabase.sh db reset && npm run setup:local",
    "setup:local": "bash scripts/setup-local.sh",
    "supabase:db:pull": "bash scripts/supabase.sh db pull",
    "supabase:migration:new": "bash scripts/supabase.sh migration new",
    "supabase:migration:up": "bash scripts/supabase.sh migration up",
    "supabase:types": "bash scripts/supabase.sh gen types typescript --local --schema public > src/lib/database.types.ts",
    "supabase:functions:serve": "bash scripts/supabase.sh functions serve",
    "supabase:functions:deploy:tag-event": "bash scripts/supabase.sh functions deploy tag-event",
    "supabase:functions:deploy:scrape-source": "bash scripts/supabase.sh functions deploy scrape-source"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.1",
    "@tanstack/react-query-devtools": "^5.99.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-is": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.16",
    "@sentry/vite-plugin": "^5.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "serve": "^14.2.6",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}