{
  "name": "family-events-monorepo",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo run dev",
    "check": "turbo run check",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "build": "turbo run build",
    "android:check": "pnpm --filter @family-events/android check",
    "android:test": "pnpm --filter @family-events/android test",
    "android:build": "pnpm --filter @family-events/android build",
    "docs:test": "node --test tests/guards/docs-coverage.test.mjs",
    "workspace:test": "node --test tests/guards/config-typescript.test.mjs tests/guards/config-quality.test.mjs tests/guards/workspace-layout.test.mjs tests/guards/packages-consumers.test.mjs tests/guards/shared-boundary.test.mjs tests/guards/domain-boundaries.test.mjs tests/guards/ios-scope.test.mjs tests/guards/android-scope.test.mjs tests/guards/workspace-workflows.test.mjs tests/railway-cron-poc.test.mjs",
    "spacelift:poc:test": "node --test tests/railway-cron-poc.test.mjs",
    "spacelift:poc:validate": "node scripts/spacelift-railway-cron-poc.mjs validate",
    "verify:workflow": "bash scripts/check-monorepo.sh",
    "test:e2e": "pnpm --filter @family-events/web test:e2e",
    "ios:generate": "pnpm --filter @family-events/ios generate",
    "ios:test": "pnpm --filter @family-events/ios test",
    "db:start": "bash scripts/supabase.sh start",
    "db:stop": "bash scripts/supabase.sh stop",
    "db:migrate": "bash scripts/supabase.sh db push",
    "db:types": "bash scripts/supabase.sh gen types typescript --local --schema public > packages/contracts/src/database.types.ts",
    "db:functions:serve": "bash scripts/supabase.sh functions serve"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "turbo": "^2.9.14",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
