{
  "name": "family-events-ui",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@11.0.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l ${PORT:-3000}",
    "typecheck": "tsc -b",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "check": "tsc -b && pnpm run lint && pnpm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev:all": "bash scripts/dev-all.sh",
    "db:start": "bash scripts/supabase.sh start",
    "db:dev": "bash scripts/supabase.sh start && npm run setup:local && bash scripts/supabase.sh functions serve",
    "db:stop": "bash scripts/supabase.sh stop",
    "db:stop:id": "bash scripts/supabase.sh stop --project-id",
    "db:status": "bash scripts/supabase.sh status",
    "db:migrate": "bash scripts/supabase.sh db push",
    "db:reset": "bash scripts/supabase.sh db reset && npm run setup:local",
    "setup:local": "bash scripts/setup-local.sh",
    "db:pull": "bash scripts/supabase.sh db pull",
    "db:migration:new": "bash scripts/supabase.sh migration new",
    "db:migration:up": "bash scripts/supabase.sh migration up",
    "db:types": "bash scripts/supabase.sh gen types typescript --local --schema public > src/lib/database.types.ts",
    "db:functions:serve": "bash scripts/supabase.sh functions serve",
    "db:functions:deploy:tag-event": "bash scripts/supabase.sh functions deploy tag-event",
    "db:functions:deploy:scrape-source": "bash scripts/supabase.sh functions deploy scrape-source"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^10.52.0",
    "@supabase/supabase-js": "^2.105.4",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-is": "^19.2.6",
    "react-map-gl": "^8.1.1",
    "react-resizable-panels": "^4.11.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "serve": "^14.2.6",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild"
    ]
  }
}
